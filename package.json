{
  "name": "aws-lens",
  "version": "0.1.0",
  "private": true,
  "author": {
    "name": "Bora Fenari Kostem",
    "email": "fenari.kostem@gmail.com"
  },
  "description": "AWS Lens — unified management console for AWS resources.",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:win": "pnpm build && electron-builder --win nsis --publish never",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip --publish never",
    "dist:linux": "pnpm build && electron-builder --linux deb AppImage --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1014.0",
    "@aws-sdk/client-auto-scaling": "^3.864.0",
    "@aws-sdk/client-cloudformation": "^3.1014.0",
    "@aws-sdk/client-cloudtrail": "^3.1014.0",
    "@aws-sdk/client-cloudwatch": "^3.1014.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1014.0",
    "@aws-sdk/client-cost-explorer": "^3.1014.0",
    "@aws-sdk/client-ec2": "^3.864.0",
    "@aws-sdk/client-ec2-instance-connect": "^3.1014.0",
    "@aws-sdk/client-ecr": "^3.1014.0",
    "@aws-sdk/client-ecs": "^3.1014.0",
    "@aws-sdk/client-eks": "^3.864.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1014.0",
    "@aws-sdk/client-iam": "^3.1014.0",
    "@aws-sdk/client-identitystore": "^3.1014.0",
    "@aws-sdk/client-kms": "^3.1014.0",
    "@aws-sdk/client-lambda": "^3.864.0",
    "@aws-sdk/client-organizations": "^3.1024.0",
    "@aws-sdk/client-rds": "^3.1014.0",
    "@aws-sdk/client-route-53": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/client-secrets-manager": "^3.1014.0",
    "@aws-sdk/client-sns": "^3.1014.0",
    "@aws-sdk/client-sqs": "^3.1014.0",
    "@aws-sdk/client-ssm": "^3.1014.0",
    "@aws-sdk/client-sso-admin": "^3.1014.0",
    "@aws-sdk/client-sts": "^3.864.0",
    "@aws-sdk/client-wafv2": "^3.1014.0",
    "@aws-sdk/credential-provider-ini": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "adm-zip": "^0.5.16",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.0"
  }
}
